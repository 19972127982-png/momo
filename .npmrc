# pnpm 11+ strict checks that break Electron postinstall flow
# - strict-dep-builds: pnpm 11 treats ignored build scripts as fatal; relax to warning
# - confirm-modules-purge: skip TTY prompt when node_modules state drifts
strict-dep-builds=false
confirm-modules-purge=false

# auto-install peer deps (React 19 + pixi v6 peer chain)
auto-install-peers=true
